APP_NAME="business-insight-agent"
ENV="development"
DATABASE_URL="sqlite:///./data/business_insight.db"
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_TO_MOCK=true
CACHE_BACKEND="memory"
REDIS_URL=""
METRICS_BACKEND=sqlite
METRICS_SERVICE_URL=
METRICS_SERVICE_TIMEOUT=5
METRICS_SERVICE_FALLBACK_TO_SQLITE=true
RAG_BACKEND="tfidf"
RAG_EMBEDDING_PROVIDER=local_hashing
RAG_EMBEDDING_MODEL=hashing-char-ngram
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_TIMEOUT=30
RAG_EMBEDDING_FALLBACK_TO_TFIDF=true
RAG_ALLOWED_SOURCES=
RAG_INDEX_MANIFEST_PATH=./data/knowledge_index_manifest.json
AGENT_RUNNER=sequential
LANGGRAPH_CHECKPOINT=none
LANGGRAPH_VISUAL_TRACE=true
EVAL_MODE=full_agent
EVAL_MIN_AVG_SCORE=0.72
EVAL_MIN_INTENT_ACCURACY=0.7
EVAL_GOLDEN_ANSWERS_PATH=evals/golden_answers.json
EVAL_HISTORY_PATH=evals/eval_history.jsonl
EVAL_HISTORY_REPORT_PATH=evals/eval_history_report.md
TRACE_ALERT_P95_LATENCY_MS=1000
TRACE_ALERT_ERROR_RATE=0.1
TRACE_TOKEN_COST_PER_1K_INPUT=0
TRACE_TOKEN_COST_PER_1K_OUTPUT=0
